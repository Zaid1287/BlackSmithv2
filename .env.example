# BlackSmith Traders — environment variables
# Copy to .env and fill in real values. NEVER commit the real .env.

# --- Required in production ---
# Postgres connection string (Neon). App refuses real DB ops without it.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT signing secret. REQUIRED in production — the server now refuses to boot
# without it (a hardcoded fallback previously let anyone forge admin tokens).
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# --- Runtime ---
NODE_ENV=production

# Port to bind. Render/most PaaS inject this automatically; defaults to 5000.
PORT=5000

# Escape hatch: set to "true" ONLY if your DB terminates TLS with an untrusted
# chain (disables certificate verification — leave unset for Neon/Render).
# DATABASE_SSL_NO_VERIFY=false

# --- One-time bootstrap (/api/init) ---
# Leave INIT_SECRET unset to disable /api/init entirely.
# To seed the admin user once: set both, call POST /api/init with header
#   X-Init-Secret: <INIT_SECRET>
# then unset INIT_SECRET again.
INIT_SECRET=
INIT_ADMIN_PASSWORD=
